# Copy this file to config/pipeline.env and edit the paths for your system.
# Do not commit config/pipeline.env if it contains private paths.

PROJECT_ROOT="$(pwd)"
RESULTS_DIR="${PROJECT_ROOT}/results"
LOG_DIR="${PROJECT_ROOT}/logs"
PREPROCESS_DIR=preprocessing

# pRESTO options
QUALITY_THRESHOLD=20
PRIMER_MAX_ERROR=0.3
MAX_PARALLEL_TASKS=2

# Chain-specific primer filtering options.
# Original workflow used IGH --maxlen 20 and TRB --maxlen 27.
IGH_PRIMER_MAXLEN=20
TRB_PRIMER_MAXLEN=27
IGH_FILTER_NPROC=5
TRB_FILTER_NPROC=
IGH_MASK_NPROC=1
TRB_MASK_NPROC=

# polyA/UMI options
POLYA_MIN_RUN=8
POLYA_SEARCH_BP=80

# MiXCR options
MIXCR_SPECIES=hsa
MIXCR_OUTDIR=mixcr
MIXCR_PRESET=generic-amplicon
ALIGNMENT_CHUNKSIZE=200000

# Large table processing options
CHUNKSIZE=50000
MAX_WORKERS=1
